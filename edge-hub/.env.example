# Copy to .env and adjust. Used by docker compose and optional native Python runs.
# Get these from your GDT Console admin (same as GDT_INGEST_API_KEY on Vercel).

# Only when using docker-compose.dist.yml (pre-built image from registry):
# GDT_EDGE_IMAGE=ghcr.io/your-github-user/gdt-edge-hub:latest

GDT_CONSOLE_API_BASE_URL=https://your-app.vercel.app
GDT_CONSOLE_API_KEY=paste-your-bearer-key-here

# Linux / Pi: path to USB-RS485 adapter (check: ls /dev/ttyUSB*  or  ls /dev/serial/by-id/)
# Must match the right side of `devices:` in docker-compose.yml (defaults to ttyUSB0).
GDT_SERIAL_DEVICE=/dev/ttyUSB0
SERIAL_DEVICE=/dev/ttyUSB0

# Host port mapping (left side)
GDT_PORT=8756
